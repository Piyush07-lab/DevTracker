{
    "name": "devtracker",
    "version": "0.1.0",
    "private": true,
    "description": "Developer activity tracking platform consisting of a VS Code extension, backend API, and dashboard.",
    "license": "MIT",
    "packageManager": "pnpm@11.16.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "format": "prettier --write .",
        "check-format": "prettier --check .",
        "typecheck": "turbo typecheck",
        "clean": "turbo clean",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "eslint": "^9.39.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.5",
        "prettier": "^3.6.2",
        "turbo": "^2.5.6",
        "typescript": "^5.9.2"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@eslint/js": "^10.0.1",
        "globals": "^17.7.0",
        "typescript-eslint": "^8.64.0"
    }
}